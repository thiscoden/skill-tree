# Server-only — never prefix with EXPO_PUBLIC_, never commit real values.
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# Client-side. Leave unset to keep the KI-Orb on the offline mock provider (M5).
# Set to the deployed backend's base URL to switch to the real LLM (M6).
EXPO_PUBLIC_QUEST_GIVER_BACKEND_URL=
